## Q.4) Compare Two Files (Command Line)

import sys

def CompareFiles(file1, file2):
    with open(file1, "r") as f1:
        data1 = f1.read()

    with open(file2, "r") as f2:
        data2 = f2.read()

    return data1 == data2


def main():
    if len(sys.argv) != 3:
        print("Usage: python program.py file1 file2")
        return

    try:
        if CompareFiles(sys.argv[1], sys.argv[2]):
            print("Success")
        else:
            print("Failure")
    except FileNotFoundError:
        print("One or both files not found.")


if __name__ == "__main__":
    main()

