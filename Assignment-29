## Q.3) Copy File Contents into a New File (Command Line)

import sys

def CopyFile(source):
    with open(source, "r") as file1:
        data = file1.read()

    with open("Demo1.txt", "w") as file2:
        file2.write(data)


def main():
    if len(sys.argv) != 2:
        print("Usage: python program.py <sourcefile>")
        return

    try:
        CopyFile(sys.argv[1])
        print("Contents copied into Demo1.txt")
    except FileNotFoundError:
        print("Source file not found.")


if __name__ == "__main__":
    main()

