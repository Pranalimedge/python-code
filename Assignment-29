## Q.2) Display File Contents

def DisplayContents(filename):
    with open(filename, "r") as file:
        print(file.read())


def main():
    filename = input("Enter file name: ")

    try:
        DisplayContents(filename)
    except FileNotFoundError:
        print("File not found.")


if __name__ == "__main__":
    main()
