# reduce() addition of all elements.

from functools import reduce

demo =lambda no1,no2:(no1+no2)

def main():
     data=[1,2,3,4,5]
     rdata=reduce(demo,data)
     print("Addition is:",rdata)

if __name__=="__main__":
     main()

