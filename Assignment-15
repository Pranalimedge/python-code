## reduce() maximum number in elements.

from functools import reduce
demo =lambda no1,no2: no1 if no1 > no2 else no2
def main():
    data=[1,2,3,4,5]
    rdata=reduce(demo,data)
    print("maximum number is:",rdata)

if __name__=="__main__":
    main()

