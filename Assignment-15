## count of even number

demo = lambda no: no % 2 == 0

def main():
    data = [1, 2, 3, 4, 5]
    fdata = list(filter(demo, data))
    print("Even numbers:", fdata)
    print("Count of even numbers:", len(fdata))

if __name__ == "__main__":
    main()


