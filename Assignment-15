##  divisible by 3 and 5

demo = lambda no: no % 3 == 0 and no % 5 == 0

def main():
    data = [15, 20, 30, 39, 45, 60]
    fdata = list(filter(demo, data))
    print("Divisible by both 3 and 5:", fdata)

if __name__ == "__main__":
    main()

