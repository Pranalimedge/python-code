# 3. Shared Counter Using Lock
import threading

counter = 0
lock = threading.Lock()

def increment():
    global counter
    for i in range(100000):
        with lock:
            counter += 1

def main():
    global counter

    t1 = threading.Thread(target=increment)
    t2 = threading.Thread(target=increment)

    t1.start()
    t2.start()

    t1.join()
    t2.join()

    print("Final Counter =", counter)

if __name__ == "__main__":
    main()

