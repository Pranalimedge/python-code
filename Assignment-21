# 4.Sum and Product Using Threads
import threading

sum_result = 0
product_result = 1

def find_sum(numbers):
    global sum_result
    sum_result = sum(numbers)

def find_product(numbers):
    global product_result
    product_result = 1
    for i in numbers:
        product_result *= i

def main():
    global sum_result, product_result

    numbers = list(map(int, input("Enter numbers: ").split()))

    t1 = threading.Thread(target=find_sum, args=(numbers,))
    t2 = threading.Thread(target=find_product, args=(numbers,))

    t1.start()
    t2.start()

    t1.join()
    t2.join()

    print("Sum =", sum_result)
    print("Product =", product_result)

if __name__ == "__main__":
    main()
