import threading

def is_prime(num):
    if num < 2:
        return False
    for i in range(2, int(num ** 0.5) + 1):
        if num % i == 0:
            return False
    return True

def prime(numbers):
    print("Prime Numbers:")
    for i in numbers:
        if is_prime(i):
            print(i, end=" ")
    print()

def nonprime(numbers):
    print("Non-Prime Numbers:")
    for i in numbers:
        if not is_prime(i):
            print(i, end=" ")
    print()

def main():
    numbers = list(map(int, input("Enter numbers: ").split()))

    t1 = threading.Thread(target=prime, args=(numbers,))
    t2 = threading.Thread(target=nonprime, args=(numbers,))

    t1.start()
    t2.start()

    t1.join()
    t2.join()

if __name__ == "__main__":
    main()

