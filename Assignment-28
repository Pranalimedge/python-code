## 3.Display File Line by Line

def DisplayFile(filename):
    with open(filename, "r") as file:
        for line in file:
            print(line, end="")


def main():
    filename = input("Enter file name: ")

    try:
        DisplayFile(filename)
    except FileNotFoundError:
        print("File not found.")


if __name__ == "__main__":
    main()

