## 4.Copy File Contents into Another File

def CopyFile(source, destination):
    with open(source, "r") as file1:
        data = file1.read()

    with open(destination, "w") as file2:
        file2.write(data)


def main():
    source = input("Enter source file: ")
    destination = input("Enter destination file: ")

    try:
        CopyFile(source, destination)
        print("Contents of", source, "copied into", destination)
    except FileNotFoundError:
        print("Source file not found.")


if __name__ == "__main__":
    main()

