def CountDigits(no):
    count = 0

    while no > 0:
        count = count + 1
        no = no // 10

    return count

def main():
    value = int(input("Enter number: "))
    print("Number of digits =", CountDigits(value))

if __name__ == "__main__":
    main()

#-----------------------------------------------------------

def SumDigits(no):
    sum = 0

    while no > 0:
        digit = no % 10
        sum = sum + digit
        no = no // 10

    return sum

def main():
    value = int(input("Enter number: "))
    print("Sum of digits =", SumDigits(value))

if __name__ == "__main__":
    main()
